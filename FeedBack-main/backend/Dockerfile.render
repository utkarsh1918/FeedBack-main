FROM node:18-alpine
WORKDIR /app

# Install dependencies including dev dependencies for Prisma
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

# Generate Prisma client
RUN npx prisma generate

# Remove dev dependencies to reduce image size
RUN npm prune --production

# Expose Render's port (usually 10000)
EXPOSE 10000

# Health check for Render
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:10000/api/health', (res) => { process.exit(res.statusCode === 200 ? 0 : 1) })"

# Start production server on Render's port
CMD ["node", "src/app.js"]
